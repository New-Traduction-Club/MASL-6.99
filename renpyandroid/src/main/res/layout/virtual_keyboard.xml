<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="false"
    android:focusable="false">

    <androidx.cardview.widget.CardView
        android:id="@+id/keyboard_drawer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/colorBackground"
        app:layout_constraintWidth_percent="0.70"
        app:layout_constraintHeight_percent="0.45"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/keyboard_rows_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="8dp" />

            <FrameLayout
                android:id="@+id/keyboard_drag_handle_container"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:clickable="true"
                android:focusable="false"
                android:background="@android:color/transparent">

                <View
                    android:id="@+id/keyboard_drag_handle"
                    android:layout_width="72dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_close_button"
                    android:backgroundTint="@color/colorPrimary" />

            </FrameLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
